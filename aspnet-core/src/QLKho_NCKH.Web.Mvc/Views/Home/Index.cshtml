				<!-- TABLE: GIAO DỊCH GẦN ĐÂY -->
				<div class="card">
					<div class="card-header border-transparent">
						<h3 class="card-title">Giao dịch gần đây</h3>
						<div class="card-tools">
							<button type="button" class="btn btn-tool" data-card-widget="collapse">
								<i class="fas fa-minus"></i>
							</button>
						</div>
					</div>
					<div class="card-body p-0">
						<div class="table-responsive">
							<table class="table m-0">
								<thead>
									<tr>
										<th>Mã giao dịch</th>
										<th>Loại</th>
										<th>Ngày</th>
										<th>Trạng thái</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var transaction in Model.RecentTransactions)
									{
										<tr>
											<td><a href="javascript:;">@transaction.TransactionCode</a></td>
											<td>@transaction.TransactionType</td>
											<td>@transaction.CreationTime.ToString("g")</td>
											<td>
												@if (transaction.Status == TransactionStatusEnum.Approved)
												{
													<span class="badge badge-success">Đã duyệt</span>
												}
												else if (transaction.Status == TransactionStatusEnum.Pending)
												{
													<span class="badge badge-warning">Chờ xử lý</span>
												}
												else
												{
													<span class="badge badge-danger">Từ chối</span>
												}
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
					<div class="card-footer clearfix">
						<a href="@Url.Action("Index", "StockTransactions")" class="btn btn-sm btn-info float-left">Xem tất cả giao dịch</a>
