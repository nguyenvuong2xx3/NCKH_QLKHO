@using QLKho_NCKH.EnumCustom
@using QLKho_NCKH.Web.Models.Home
@using QLKho_NCKH.Web.Startup
@model DashboardViewModel
@{
	ViewBag.Title = L("TrangChủ");
	ViewBag.CurrentPageName = PageNames.Home;
}

<!-- Phần script đặt ở cuối view -->
@section scripts
{
	<environment names="Development">
		<script src="~/libs/chartjs/dist/Chart.js" asp-append-version="true"></script>
		<script src="~/view-resources/Views/Home/Index.js" asp-append-version="true"></script>
	</environment>

	<environment names="Staging,Production">
		<script src="~/view-resources/Views/_Bundles/home-index.min.js" asp-append-version="true"></script>
	</environment>

	<script>
		$(function () {
				// Biểu đồ giao dịch
				var ctx = document.getElementById('transactionsChart').getContext('2d');

				// Tạo nhãn cho 30 ngày gần nhất
				var labels = [];
				for (var i = 29; i >= 0; i--) {
						var date = new Date();
						date.setDate(date.getDate() - i);
						labels.push(date.toLocaleDateString('vi-VN', { month: 'short', day: 'numeric' }));
				}

				// Dữ liệu mẫu (thay bằng dữ liệu thực từ service)
				var data = [];
				for (var i = 0; i < 30; i++) {
						data.push(Math.floor(Math.random() * 10) + 1);
				}

				var chart = new Chart(ctx, {
						type: 'line',
						data: {
								labels: labels,
								datasets: [{
										label: 'Giao dịch',
										backgroundColor: 'rgba(60,141,188,0.9)',
										borderColor: 'rgba(60,141,188,0.8)',
										pointRadius: false,
										pointColor: '#3b8bba',
										pointStrokeColor: 'rgba(60,141,188,1)',
										pointHighlightFill: '#fff',
										pointHighlightStroke: 'rgba(60,141,188,1)',
										data: data
								}]
						},
						options: {
								responsive: true,
								maintainAspectRatio: false,
								scales: {
										y: {
												beginAtZero: true,
												ticks: {
														stepSize: 1
												}
										}
								}
						}
				});
		});
	</script>
}

