@using QLKho_NCKH.Web.Models.Common.Modals
@using QLKho_NCKH.Web.Models.Categories
@model EditCategoryViewModel

@{
	Layout = null;
}

@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditCategory")))

<form name="CategoryEditForm" role="form" class="form-horizontal">
	<input type="hidden" name="Id" value="@Model.Category.Id" />

	<div class="modal-body">
		<div class="form-group row required">
			<label class="col-md-3 col-form-label" for="categoryName">@L("CategoryName")</label>
			<div class="col-md-9">
				<input id="Name" type="text" class="form-control" name="Name" value="@Model.Category.Name" required maxlength="250">
			</div>
		</div>

		<div class="form-group row">
			<label class="col-md-3 col-form-label" for="categoryDescription">@L("CategoryDescription")</label>
			<div class="col-md-9">
				<textarea id="Description" class="form-control" name="Description" rows="3">@Model.Category.Description</textarea>
			</div>
		</div>

	</div>

	@await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

<script src="~/view-resources/Views/Categories/_EditModal.js" asp-append-version="true"></script>
