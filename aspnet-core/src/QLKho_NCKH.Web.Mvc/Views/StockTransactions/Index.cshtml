@using QLKho_NCKH.Web.Models.storageLocations
@using QLKho_NCKH.Web.Startup
@model storageLocationListViewModel
@{
  ViewBag.Title = L("StockTransactions");
  ViewBag.CurrentPageName = PageNames.StockTransactions;
}
@section scripts
{
  <environment names="Development">
    <script src="~/view-resources/Views/StockTransactions/Index.js" asp-append-version="true"></script>
  </environment>

  <environment names="Staging,Production">
    <script src="~/view-resources/Views/StockTransactions/Index.min.js" asp-append-version="true"></script>
  </environment>
  <environment names="Development">
    <script src="~/view-resources/Views/StockTransactions/_ImportModal.js" asp-append-version="true"></script>
  </environment>

  <environment names="Staging,Production">
    <script src="~/view-resources/Views/StockTransactions/_ImportModal.min.js" asp-append-version="true"></script>
  </environment>

    <environment names="Development">
    <script src="~/view-resources/Views/StockTransactions/_ExportModal.js" asp-append-version="true"></script>
  </environment>

  <environment names="Staging,Production">
    <script src="~/view-resources/Views/StockTransactions/_ExportModal.min.js" asp-append-version="true"></script>
  </environment>

  <environment names="Development">
    <script src="~/view-resources/Views/StockTransactions/_TransferModal.js" asp-append-version="true"></script>
  </environment>

  <environment names="Staging,Production">
    <script src="~/view-resources/Views/StockTransactions/_TransferModal.min.js" asp-append-version="true"></script>
  </environment>
}

<section class="content-header">
  <div class="container-fluid">
    <div class="row">
      <div class="col-sm-6">
        <h1>@L("StockTransactions")</h1>
      </div>
      <div class="col-sm-6 ">
        <div class="dropdown float-sm-right" style="padding-right: 50px;">
          <button class="btn bg-blue dropdown-toggle" type="button" id="transactionTypeDropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="fa fa-plus-square"></i> @L("Create")
          </button>
          <div class="dropdown-menu" aria-labelledby="transactionTypeDropdown">
            <a class="dropdown-item" href="javascript:;" data-toggle="modal" data-target="#ImportModal">@L("Nhập kho")</a>
            <a class="dropdown-item" href="javascript:;" data-toggle="modal" data-target="#ExportModal">@L("Xuất kho")</a>
            <a class="dropdown-item" href="javascript:;" data-toggle="modal" data-target="#TransferModal">@L("Điều chuyển")</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <div class="row">
              <div class="col-md-6">
                <!--Use for bulk actions-->
              </div>
              <div class="col-md-6">
                @await Html.PartialAsync("~/Views/StockTransactions/Index.AdvancedSearch.cshtml")
              </div>
            </div>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table id="StockTransactionsTable" class="table table-striped table-bordered">
                <thead>
                  <tr>
                    <th>@L("TransactionCode")</th>
                    <th>@L("TransactionType")</th>
                    @* <th>@L("FromWarehouse")</th> *@
                    @* <th>@L("ToWarehouse")</th> *@
                    <th>@L("ReferenceNumber")</th>
                    <th>@L("Status")</th>
                    <th>@L("Actions")</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

@await Html.PartialAsync("~/Views/StockTransactions/_CreateImportModal.cshtml", Model)
@await Html.PartialAsync("~/Views/StockTransactions/_CreateExportModal.cshtml", Model)
@await Html.PartialAsync("~/Views/StockTransactions/_CreateTransferModal.cshtml", Model)

<div class="modal fade" id="StockTransactionEditModal" tabindex="-1" role="dialog" aria-labelledby="UserEditModalLabel" data-backdrop="static">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
    </div>
  </div>
</div>
