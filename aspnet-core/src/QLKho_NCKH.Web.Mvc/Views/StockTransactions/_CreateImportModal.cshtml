@using Abp.Authorization.Users
@using QLKho_NCKH.Web.Models.Common.Modals
@using QLKho_NCKH.Web.Models.storageLocations
@model storageLocationListViewModel
@{
	Layout = null;
}
<div class="modal fade" id="ImportModal" tabindex="-1" role="dialog" aria-labelledby="ImportModalLabel" data-backdrop="static">
	<div class="modal-dialog modal-lg" role="document">
		<div class="modal-content">
      @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("CreateNewImportStorageLocation")))
      <form name="StorageLocationCreateForm" role="form" class="form-horizontal">
				<div class="modal-body">
          <div class="tab-content mt-4">
            <div role="tabpanel" class="tab-pane container active" id="create-supplier-details">
              <div class="form-group row required">
                <label class="col-md-3 col-form-label">@L("WarehouseName")</label>
                <div class="input-group">
                  <input type="text" id="WarehouseImportDisplay" class="form-control" readonly required />
                  <button type="button" id="CreateWarehouseImportBtn" class="btn btn-success btn-sm" title="@L("WarehouseName")">
                    <i class="fa fa-id-card"></i>
                  </button>
                </div>
                <input type="hidden" id="WarehouseIdImportCreate" name="ToWarehouseId" />
              </div>
              
              <div class="form-group row required">
                <label class="col-md-3 col-form-label">@L("Supplier")</label>
                <div class="input-group">
                  <input type="text" id="SupplierImportDisplay" class="form-control" readonly required />
                  <button type="button" id="AddSupplierImportBtn" class="btn btn-success btn-sm" title="@L("Supplier")">
                    <i class="fa fa-id-card"></i>
                  </button>
                </div>
                <input type="hidden" id="SupplierIdImportCreate" name="SupplierId" />
              </div>

              <div class="form-group row required">
                <label class="col-md-3 col-form-label">@L("Products")</label>
                <div class="input-group">
                  <input type="text" id="ProductsImportDisplay" class="form-control" readonly required />
                  <button type="button" id="AddProductsImportBtn" class="btn btn-success btn-sm" title="@L("Products")">
                    <i class="fa fa-id-card"></i>
                  </button>
                </div>
                <input type="hidden" id="ProductsIdImportCreate" name="ProductId" />
              </div>

              @* <div class="form-group row required"> *@
              @*   <label class="col-md-3 col-form-label">@L("Products")</label> *@
              @*   <div class="input-group"> *@
              @*     <input type="text" id="ProductsImportDisplay" class="form-control" readonly required /> *@
              @*     <button type="button" id="AddProductsImportBtn" class="btn btn-success btn-sm" title="@L("Products")"> *@
              @*       <i class="fa fa-id-card"></i> *@
              @*     </button> *@
              @*   </div> *@
              @*   <input type="hidden" id="ProductsIdImportCreate" name="ProductId" /> *@
              @* </div> *@
              <!-- Trạng thái hoạt động -->
              @* <div class="form-group row"> *@
              @*   <label class="col-md-3 col-form-label">@L("IsAvailable")</label> *@
              @*   <div class="col-md-9"> *@
              @*     <input type="checkbox" name="IsAvailable" value="true" checked /> *@
              @*   </div> *@
              @* </div> *@
            </div>
          </div>
        </div>
				@await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
			</form>
		</div>
	</div>
</div>
<style>
  .modal {
    z-index: 1050 !important;
  }

  .modal-backdrop {
    z-index: 1040 !important;
  }
</style>