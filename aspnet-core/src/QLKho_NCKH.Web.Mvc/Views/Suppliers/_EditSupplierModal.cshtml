@using Abp.Authorization.Users
@using QLKho_NCKH.Web.Models.Common.Modals
@using QLKho_NCKH.Web.Models.Suppliers
@model EditSuppliersModalViewModel
@{
	Layout = null;
}
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditUser")))
<script src="~/view-resources/Views/Suppliers/_EditModal.js" asp-append-version="true"></script>

<form name="SupplierEditForm" role="form" class="form-horizontal">
	<input type="hidden" name="Id" value="@Model.Id" />
	<div class="modal-body">
		<div class="tab-content mt-4">
			<div role="tabpanel" class="tab-pane container active" id="create-supplier-details">
				<!-- Tên nhà cung cấp -->
				<div class="form-group row required">
					<label class="col-md-3 col-form-label">@L("Name")</label>
					<div class="col-md-9">
						<input type="text" class="form-control" name="Name" value="@Model.Name" required maxlength="256">
					</div>
				</div>
				<div class="form-group row required">
					<label class="col-md-3 col-form-label">@L("Code")</label>
					<div class="col-md-9">
						<input type="text" class="form-control" name="Code" value="@Model.Code" required maxlength="256">
					</div>
				</div>


				<!-- Địa chỉ -->
				<div class="form-group row">
					<label class="col-md-3 col-form-label">@L("Address")</label>
					<div class="col-md-9">
						<input type="text" class="form-control" name="Address" value="@Model.Address" maxlength="500">
					</div>
				</div>

				<!-- Số điện thoại -->
				<div class="form-group row required">
					<label class="col-md-3 col-form-label">@L("PhoneNumber")</label>
					<div class="col-md-9">
						<input type="tel" class="form-control" name="PhoneNumber" value="@Model.PhoneNumber" required maxlength="20">
					</div>
				</div>

				<!-- Email -->
				<div class="form-group row">
					<label class="col-md-3 col-form-label">@L("Email")</label>
					<div class="col-md-9">
						<input type="email" class="form-control" name="Email" value="@Model.Email" maxlength="256">
					</div>
				</div>

				<!-- Mã số thuế -->
				<div class="form-group row">
					<label class="col-md-3 col-form-label">@L("TaxCode")</label>
					<div class="col-md-9">
						<input type="text" class="form-control" name="TaxCode" value="@Model.TaxCode" maxlength="50">
					</div>
				</div>

				<!-- Trạng thái hoạt động -->
				<div class="form-group row">
					<label class="col-md-3 col-form-label">@L("IsActive")</label>
					<div class="col-md-9">
						<input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
					</div>
				</div>
			</div>
		</div>
	</div>
		@await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

