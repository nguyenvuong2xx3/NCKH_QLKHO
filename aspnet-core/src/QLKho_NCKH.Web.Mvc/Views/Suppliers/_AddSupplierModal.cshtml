@using QLKho_NCKH.Web.Models.Common.Modals
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(@L("SelectSupplier")))

<div class="modal-body">
  <form>
    <div class="input-group">
      <input id="SupplierFilter" name="SupplierFilter" class="form-control add-supplier-filter-text"
             placeholder="@L("SearchWithSupplierName")" type="text">
      <button class="btn btn-primary add-supplier-filter-button" type="button">
        <i class="fa fa-search" aria-label="@L("Search")"></i>
      </button>
    </div>
  </form>
  <table id="addSupplierModalTable" class="table align-middle table-row-dashed fs-6 gy-5 dataTable dtr-inline no-footer w-100">
    <thead>
      <tr>
        <th>@L("Select")</th>
        <th>@L("Name")</th>
        <th>@L("Address")</th>
        <th>@L("PhoneNumber")</th>
        <th>@L("IsActive")</th>
      </tr>
    </thead>
    <tbody>
    </tbody>
  </table>
</div>

@await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
