@* @using QLKho_NCKH.Authorization *@
@using QLKho_NCKH.Authorization
@using QLKho_NCKH.Web.Startup
@using QLKho_NCKH.Web.Models.Products
@model ProductViewModel
@{
	// ViewBag.CurrentPageName = PermissionNames.;
	ViewBag.Title = L("Products");
	ViewBag.CurrentPageName = PageNames.Products;
}

@section scripts
{
	<environment names="Development">
		<script src="~/view-resources/Views/Products/Index.js" asp-append-version="true"></script>
	</environment>

	<environment names="Staging,Production">
		<script src="~/view-resources/Views/Products/Index.min.js" asp-append-version="true"></script>
	</environment> 
}


<section class="content-header">
	<div class="container-fluid">
		<div class="row">
			<div class="col-sm-6">
				<h1>@L("Products")</h1>
			</div>
			@* <div class="col-sm-6"> *@
			@* 	@if (IsGranted(PermissionNames.Pages_Products_Create)){ *@
			@* 		<a href="javascript:;" class="btn bg-blue float-sm-right" data-target="#ProductCreateModal" data-toggle="modal"> *@
			@* 		<i class="fa fa-plus-square"></i> *@
			@* 		@L("Create") *@
			@* 	</a> *@
			@* 	} *@
			@* </div> *@
			<div class="col-sm-6">
				@if (IsGranted(PermissionNames.Pages_Products_Create))
				{
					<div class="btn-group float-sm-right">
						<button type="button" class="btn bg-green dropdown-toggle" data-toggle="dropdown">
							<i class="fa fa-file-excel"></i> Excel
						</button>
						<div class="dropdown-menu">
							<a class="dropdown-item" href="javascript:;" id="ExportExcelBtn">Xuất Excel</a>
							<a class="dropdown-item" href="javascript:;" data-toggle="modal" data-target="#ImportExcelModal">Nhập Excel</a>
						</div>
					</div>

					<a href="javascript:;" class="btn bg-blue float-sm-right mr-2" data-target="#ProductCreateModal" data-toggle="modal">
						<i class="fa fa-plus-square"></i>
						@L("Create")
					</a>
				}
			</div>
		</div>
	</div>
</section>
<section class="content">
	<div class="container-fluid">
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header">
						<div class="row">
							<div class="col-md-6">
							</div>

							<div class="col-md-6">
								@* @await Html.PartialAsync("~/Views/Products/Search.cshtml") *@
							</div>
						</div>
					</div>
					<div class="card-body">
						<div class="table-responsive">
							<table id="ProductsTable" class="table table-striped table-bordered">
								<thead>
									<tr>
										<th>Code</th>
										<th>Name</th>
										<th>Image</th>
										<th>Description</th>
										<th>Category</th>
										<th>Barcode</th>
										<th>Unit</th>
										<th>Weight</th>
										<th>Volume</th>
										<th>Supplier</th>
										<th>Is Active</th>
										<th>Action</th>
									</tr>
								</thead>
								<tbody>
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

@await Html.PartialAsync("~/Views/Products/_CreateModal.cshtml", Model)



<div class="modal fade" id="ProductEditModal" tabindex="-1" role="dialog" aria-labelledby="ProductEditModalLabel" data-backdrop="static">
	<div class="modal-dialog modal-lg" role="document">
		<div class="modal-content">
		</div>
	</div>
</div>
<!-- Thêm vào cuối file -->
<div class="modal fade" id="ImportExcelModal" tabindex="-1" role="dialog" aria-labelledby="ImportExcelModalLabel">
	<div class="modal-dialog" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h4 class="modal-title">Nhập sản phẩm từ Excel</h4>
				<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<form id="ImportExcelForm" method="post" enctype="multipart/form-data">
				<div class="modal-body">
					<div class="form-group">
						<label>File Excel</label>
						<input type="file" name="file" class="form-control" accept=".xlsx" required />
					</div>
					<div class="form-group">
						<a href="/templates/ProductImportTemplate.xlsx" class="btn btn-sm btn-info">
							<i class="fa fa-download"></i> Tải file mẫu
						</a>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-default" data-dismiss="modal">Đóng</button>
					<button type="submit" class="btn btn-primary">Nhập dữ liệu</button>
				</div>
			</form>
		</div>
	</div>
</div>







