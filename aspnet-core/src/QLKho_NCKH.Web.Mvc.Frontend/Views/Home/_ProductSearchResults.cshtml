@using QLKho_NCKH.Web.Models.Products
@model ProductSearchViewModel;

<link href="/css/homeweb.css" rel="stylesheet" />
<link href="~/css/style.css" rel="stylesheet" />



<div class="container-product mt-3">
	<div class="row">
		<div class="col-md-12">
			<!-- Breadcrumb -->
			<nav aria-label="breadcrumb">
				<ol class="breadcrumb bg-light p-2 pr-0 rounded">
					<li class="breadcrumb-item"><a href="/Home">Trang chủ</a></li>
					<li class="breadcrumb-item"><a href="/Home">Tìm kiếm</a></li>
					@* @if (Model.CategoryId.HasValue) *@
					@* { *@
					@* 		<li class="breadcrumb-item active" aria-current="page"> *@
					@* 		@* <a href="/Home/PageAllProduct?categoryId=@Model.CategoryId"></a> *@ 
					@* 		@Model.CategoryName *@
					@* 		</li> *@
					@* } *@
					@* else *@
					@* { *@
					@* 		<li class="breadcrumb-item active" aria-current="page">Kết quả tìm kiếm <span>@Model.Products.Count</span></li> *@
					@* } *@
				</ol>
			</nav>
		</div>
	</div>
</div>


<style>
	.container-product {
		width: 100%;
		padding: 10px 185px;
		margin-left: 10px;
	}

	.container-items {
		display: flex;
		flex-wrap: wrap;
	}
</style>


<div class="container-product">
	<div class="mb-5">
		<h4 class="mb-3">Sắp xếp theo</h4>
		<div class="d-flex" style="gap: 30px">
			<div>
				<a class="related-tag btn-sort" href="#" value="price_desc"><i class="fas fa-sort-amount-down ml-1"></i>Giá cao - thấp </a>
			</div>
			<div>
				<a class="related-tag btn-sort" href="#" value="price_asc"><i class="fas fa-sort-amount-up"></i>Giá thấp - cao</a>
			</div>
		</div>
	</div>
	<div class="container-items" id="productPage">
		@* @await Html.PartialAsync("_GetProductPage", Model) *@
		@foreach (var product in Model.Items)
		{
			<div class="swiper-slide me-1" style="width: 220px; margin-right: 10px">
				<div class="card mb-3">
					<div class="card-body">
						<!-- Hình ảnh sản phẩm -->
						<div class="product-image text-center">
							<img class="product-image btn-view-detail" style="width: 160px; height: 160px;"
									 @* src="@(string.IsNullOrEmpty(product.) ? "/img/default.jpg" : product.Image)" *@
									 alt="@product.ProductName"
									 data-id="@product.Id">
						</div>

						<!-- Tên sản phẩm -->
						<div class="product-name">
							<h6 class="card-title">@product.ProductName</h6>
						</div>

						<!-- Giá sản phẩm -->
						<p class="card-text product_price text-danger fw-bold text-center">
							@* @String.Format("{0:N0} đ", product.Price) *@ @product.UnitPrice
						</p>

						<!-- Giảm giá SMember -->
						<div class="block-smem-price text-center">
							Smember giảm thêm đến <span class="text-danger">10%</span>
						</div>

						<!-- Khu vực đánh giá và yêu thích -->
						<div class="bottom-div d-flex justify-content-between align-items-center mt-2">
							<!-- Đánh giá -->
							<div class="product-rating">
								<i class="fas fa-star text-warning"></i>
								<i class="fas fa-star text-warning"></i>
								<i class="fas fa-star text-warning"></i>
								<i class="fas fa-star text-warning"></i>
								<i class="fas fa-star text-warning"></i>
							</div>

							<!-- Nút yêu thích -->
							<div>
								<a href="#" class="favorite-btn text-decoration-none">
									Yêu thích
								</a>
								<i class="far fa-heart text-danger"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
</div>


 <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script> 

@section scripts
{
	<script src="~/view-resources/Views/Home/Page.js"></script>
	<script src="~/view-resources/Views/Home/Index.js"></script>
}
