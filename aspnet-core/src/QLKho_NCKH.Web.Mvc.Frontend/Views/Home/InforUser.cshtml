@using QLKho_NCKH.Web.Models.Users
@model UserViewModel

@{
  ViewData["Title"] = "User Profile";
  var userId = ViewBag.UserId;
	var status = ViewBag.Status;
}

<div class="container mt-3">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      <div class="card shadow-lg">
        <!-- Header -->
        <div class="card-header bg-primary text-white text-center py-4">
          <h2 class="mb-0">User Profile</h2>
        </div>

        <!-- Body -->
        <div class="card-body">
          <div class="row">
            <!-- Avatar Section -->
            <div class="col-lg-4 text-center">
              <img src="https://via.placeholder.com/200" alt="User Avatar" class="rounded-circle mb-3" style="width: 200px; height: 200px;">
              <h4 class="mt-2 font-weight-bold">@Model.FullName</h4>
            </div>

            <!-- User Information Section -->
            <div class="col-lg-8">
              <h5 class="font-weight-bold text-primary mb-3">Personal Information</h5>
              <div class="row">
                <div class="col-md-6 mb-3">
                  <p><strong>Email:</strong> @Model.EmailAddress</p>
                </div>
                <div class="col-md-6 mb-3">
                  <p><strong>Phone Number:</strong> @Model.PhoneNumber</p>
                </div>
                <div class="col-md-6 mb-3">
                  <p><strong>Member Since:</strong> @Model.CreationTime</p>
                </div>
                <div class="col-md-6 mb-3">
                  <p>
                    <strong>Status:</strong>
                    @if (Model.IsActive)
                    {
                      <span class="badge badge-success">Active</span>
                    }
                    else
                    {
                      <span class="badge badge-danger">Inactive</span>
                    }
                  </p>
                </div>
              </div>

              <h5 class="font-weight-bold text-primary mt-4">Additional Information</h5>
              <p><strong>Address:</strong> @Model.Address</p>
            </div>
          </div>
        </div>

        <!-- Footer Buttons -->
        <div class="card-footer bg-light py-4">
          <div class="row text-center">
            <div class="col-md-3 mb-3">
              <a href="/User/Edit" class="btn btn-primary btn-block">Edit Profile</a>
            </div>
            <div class="col-md-3 mb-3">
              <a href="/User/ChangePassword" class="btn btn-warning btn-block">Change Password</a>
            </div>
            <div class="col-md-3 mb-3">
              @* <a href="/Orders/Tracking" class="btn btn-info btn-block">Track Orders</a> *@
              <a href="@Url.Action("History", "Orders", new { userId = userId, status = status })"
                 class="btn btn-info btn-block">Theo dõi đơn hàng</a>
            </div>
            <div class="col-md-3 mb-3">
              <a href="/User/Logout" class="btn btn-danger btn-block">Logout</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
