@using QLKho_NCKH.Web.Models.Common.Modals
@using QLKho_NCKH.Web.Models.Customers
@model EditCustomerViewModel

@{
  Layout = null;
}

@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditCustomer")))

<form name="CustomerEditForm" role="form" class="form-horizontal">
  <input type="hidden" name="Id" value="@Model.Customer.Id" />

  <div class="modal-body">
    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("Code")</label>
      <div class="col-md-9">
        <input type="text" class="form-control" name="Code" value="@Model.Customer.Code" required maxlength="50" placeholder="Customer code...">
      </div>
    </div>

    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("Name")</label>
      <div class="col-md-9">
        <input type="text" class="form-control" name="Name" value="@Model.Customer.Name" required maxlength="100" placeholder="Customer name...">
      </div>
    </div>

    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("Address")</label>
      <div class="col-md-9">
        <input type="text" class="form-control" name="Address" value="@Model.Customer.Address" maxlength="200" placeholder="Customer address...">
      </div>
    </div>

    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("PhoneNumber")</label>
      <div class="col-md-9">
        <input type="tel" class="form-control" name="PhoneNumber" value="@Model.Customer.PhoneNumber" maxlength="20" placeholder="Phone number...">
      </div>
    </div>

    <div class="form-group row">
      <label class="col-md-3 col-form-label">@L("Email")</label>
      <div class="col-md-9">
        <input type="email" class="form-control" name="Email" value="@Model.Customer.Email" maxlength="100" placeholder="Email address...">
      </div>
    </div>

    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("TaxCode")</label>
      <div class="col-md-9">
        <input type="text" class="form-control" name="TaxCode" value="@Model.Customer.TaxCode" maxlength="20" placeholder="Tax code...">
      </div>
    </div>

    <div class="form-group row required">
      <label class="col-md-3 col-form-label">@L("IsActive")</label>
      <div class="col-md-9">
        <select class="form-control" name="IsActive" required>
          <option value="true" selected="@(Model.Customer.IsActive ? "selected" : null)">Active</option>
          <option value="false" selected="@(!Model.Customer.IsActive ? "selected" : null)">Inactive</option>
        </select>
      </div>
    </div>
  </div>

  @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

<style>
  .has-error .form-control {
    border-color: #d9534f;
  }

  .error {
    color: #d9534f;
    font-size: 0.875em;
    margin-top: 0.25rem;
  }
</style>

<script src="~/view-resources/Views/Customers/_EditModal.js" asp-append-version="true"></script>