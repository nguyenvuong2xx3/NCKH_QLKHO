@using QLKho_NCKH.EnumCustom
@using QLKho_NCKH.Web.Models
@model StockTransactionHistoryViewModel

@{
	var transactions = Model?.Transactions ?? new List<StockTransactionDetailViewModel>();
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/view-resources/Views/Carts/History.js"></script>


<div class="container mt-3 mb-5">
	<div class="card">
		<div class="card-header">
			<h3 class="card-title">Lịch sử đơn hàng</h3>
			<div class="card-tools">
				<form method="get" class="form-inline">
					<div class="input-group input-group-sm">
						<input type="text" name="Filter" class="form-control" placeholder="Tìm kiếm..." value="@Model.Filter">
						<div class="input-group-append">
							<button type="submit" class="btn btn-primary">
								<i class="fas fa-search"></i>
							</button>
						</div>
					</div>

					<div class="form-group ml-2">
						<select asp-for="Status" asp-items="Html.GetEnumSelectList<TransactionStatusEnum>()" class="form-control form-control-sm">
							<option value="">-- Tất cả trạng thái --</option>
						</select>
					</div>

					<div class="form-group ml-2">
						<input type="date" asp-for="StartTime" class="form-control form-control-sm" placeholder="Từ ngày">
					</div>

					<div class="form-group ml-2">
						<input type="date" asp-for="EndTime" class="form-control form-control-sm" placeholder="Đến ngày">
					</div>
				</form>
			</div>
		</div>

		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover">
					<thead>
						<tr>
							<th>Mã đơn</th>
							<th>Ngày đặt</th>
							<th>Loại đơn</th>
							<th>Tổng sản phẩm</th>
							<th>Tổng tiền</th>
							<th>Trạng thái</th>
							<th>Thao tác</th>
						</tr>
					</thead>
					<tbody>
						@if (transactions.Any())
						{
							@foreach (var transaction in transactions)
							{
								<tr>
									<td>@(transaction.TransactionCode ?? "N/A")</td>
									<td>@transaction.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
									<td>
										@if (transaction.TransactionType == TransactionType.Import)
										{
											<span class="badge badge-success">Nhập kho</span>
										}
										else
										{
											<span class="badge badge-warning">Xuất kho</span>
										}
									</td>
									<td>@(transaction.Products?.Sum(p => p.Quantity) ?? 0)</td>
									<td>@(transaction.Products?.Sum(p => p.TotalPrice).ToString("N0") ?? "0") đ</td>
									<td>
										@switch (transaction.Status)
										{
											case TransactionStatusEnum.Pending:
												<span class="badge badge-info">Chờ duyệt</span>
												break;
											case TransactionStatusEnum.Approved:
												<span class="badge badge-success">Đã duyệt</span>
												break;
											case TransactionStatusEnum.Completed:
												<span class="badge badge-primary">Hoàn thành</span>
												break;
											case TransactionStatusEnum.Cancelled:
												<span class="badge badge-danger">Đã hủy</span>
												break;
											default:
												<span class="badge badge-secondary">@transaction.Status</span>
												break;
										}
									</td>
									<td>
										<button class="btn btn-sm btn-info view-details" data-id="@transaction.TransactionId">
											<i class="fas fa-eye"></i> Chi tiết
										</button>
									</td>
								</tr>
							}
						}
						else
						{
							<tr>
								<td colspan="7" class="text-center">Không có đơn hàng nào</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>

		@if (Model.TotalCount > 0)
		{
			<div class="card-footer clearfix">
				<ul class="pagination pagination-sm m-0 float-right">
					@if (Model.CurrentPage > 1)
					{
						<li class="page-item">
							<a class="page-link"
								 href="@Url.Action("History", new {
                           Filter = Model.Filter,
                           Status = Model.Status,
                           StartTime = Model.StartTime,
                           EndTime = Model.EndTime,
                           SkipCount = 0,
                           MaxResultCount = Model.PageSize
                       })">&laquo;</a>
						</li>
						<li class="page-item">
							<a class="page-link"
								 href="@Url.Action("History", new {
                           Filter = Model.Filter,
                           Status = Model.Status,
                           StartTime = Model.StartTime,
                           EndTime = Model.EndTime,
                           SkipCount = (Model.CurrentPage - 2) * Model.PageSize,
                           MaxResultCount = Model.PageSize
                       })">&lsaquo;</a>
						</li>
					}

					@for (int i = 1; i <= Model.TotalPages; i++)
					{
						<li class="page-item @(i == Model.CurrentPage ? "active" : "")">
							<a class="page-link"
								 href="@Url.Action("History", new {
                           Filter = Model.Filter,
                           Status = Model.Status,
                           StartTime = Model.StartTime,
                           EndTime = Model.EndTime,
                           SkipCount = (i - 1) * Model.PageSize,
                           MaxResultCount = Model.PageSize
                       })">@i</a>
						</li>
					}

					@if (Model.CurrentPage < Model.TotalPages)
					{
						<li class="page-item">
							<a class="page-link"
								 href="@Url.Action("History", new {
                           Filter = Model.Filter,
                           Status = Model.Status,
                           StartTime = Model.StartTime,
                           EndTime = Model.EndTime,
                           SkipCount = Model.CurrentPage * Model.PageSize,
                           MaxResultCount = Model.PageSize
                       })">&rsaquo;</a>
						</li>
						<li class="page-item">
							<a class="page-link"
								 href="@Url.Action("History", new {
                           Filter = Model.Filter,
                           Status = Model.Status,
                           StartTime = Model.StartTime,
                           EndTime = Model.EndTime,
                           SkipCount = (Model.TotalPages - 1) * Model.PageSize,
                           MaxResultCount = Model.PageSize
                       })">&raquo;</a>
						</li>
					}
				</ul>
				<div class="float-left mt-2">
					Hiển thị @((Model.CurrentPage - 1) * Model.PageSize + 1) -
					@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)
					trong tổng số @Model.TotalCount đơn hàng
				</div>
			</div>
		}
	</div>
</div>

<!-- Modal for order details -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1" role="dialog" aria-hidden="true">
	<div class="modal-dialog modal-lg" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Chi tiết đơn hàng <span id="orderCode"></span></h5>
				<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<div class="modal-body">
				<div class="row mb-3">
					<div class="col-md-6">
						<strong>Ngày đặt:</strong> <span id="orderDate"></span>
					</div>
					<div class="col-md-6">
						<strong>Trạng thái:</strong> <span id="orderStatus"></span>
					</div>
				</div>
				<div class="row mb-3">
					<div class="col-md-6">
						<strong>Loại đơn:</strong> <span id="orderType"></span>
					</div>
					<div class="col-md-6">
						<strong>Tổng tiền:</strong> <span id="orderTotal"></span>
					</div>
				</div>

				<h6 class="mt-4 mb-3">Danh sách sản phẩm</h6>
				<div class="table-responsive">
					<table class="table table-bordered">
						<thead>
							<tr>
								<th>STT</th>
								<th>Mã SP</th>
								<th>Tên SP</th>
								<th>Số lượng</th>
								<th>Đơn giá</th>
								<th>Thành tiền</th>
							</tr>
						</thead>
						<tbody id="productList">
							<!-- Product list will be populated here -->
						</tbody>
					</table>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
			</div>
		</div>
	</div>
</div>

<style>
	.pagination {
		margin: 0;
	}

	.page-item.active .page-link {
		background-color: #007bff;
		border-color: #007bff;
	}

	.page-link {
		color: #007bff;
	}
</style>