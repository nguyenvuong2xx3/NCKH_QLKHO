@using QLKho_NCKH.Web.Models.Common.Modals
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(@L("SelectWarehouse")))

<div class="modal-body">
  <form>
    <div class="input-group">
      <input type="text" id="ProductFilter" class="form-control" placeholder="Tìm kiếm sản phẩm...">
      <div class="input-group-append">
        <button class="btn btn-primary add-product-filter-button" type="button">
          <i class="fa fa-search"></i>
        </button>
      </div>
    </div>
  </form>
  <table id="addProductModalTable" class="table table-striped table-bordered" style="width:100%">
    <thead>
      <tr>
        <th width="5%"></th>
        <th width="20%">Mã sản phẩm</th>
        <th width="40%">Tên sản phẩm</th>
        <th width="15%">Đơn vị</th>
        <th width="20%">Barcode</th>
      </tr>
    </thead>
    <tbody>
    </tbody>
  </table>
</div>

@await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")