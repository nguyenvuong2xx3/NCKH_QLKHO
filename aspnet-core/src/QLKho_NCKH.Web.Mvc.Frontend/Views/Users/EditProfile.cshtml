@using QLKho_NCKH.Web.Models.Users
@model EditUserModalViewModel

@section Scripts
{
  <script abp-src="/view-resources/Views/Profile/EditProfile.js" asp-append-version="true"></script>
}

<div class="card">
  <div class="card-header">
    <h5>@L("EditProfile")</h5>
  </div>
  <div class="card-body">
    <form id="EditProfileForm">
      <div class="form-group">
        <label for="Name">@L("Name")</label>
        <input type="text" class="form-control" id="Name" name="Name" value="@Model.User.Name">
      </div>
      <div class="form-group">
        <label for="Surname">@L("Surname")</label>
        <input type="text" class="form-control" id="Surname" name="Surname" value="@Model.User.Surname">
      </div>
      <div class="form-group">
        <label for="EmailAddress">@L("EmailAddress")</label>
        <input type="email" class="form-control" id="EmailAddress" name="EmailAddress" value="@Model.User.EmailAddress">
      </div>
      <div class="form-group">
        <label for="PhoneNumber">@L("PhoneNumber")</label>
        <input type="tel" class="form-control" id="PhoneNumber" name="PhoneNumber" value="@Model.User.PhoneNumber">
      </div>
      <button type="submit" id="SaveProfileButton" class="btn btn-primary">
        <i class="fa fa-save"></i> @L("Save")
      </button>
    </form>
  </div>
</div>