@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*                 <div> *@
@*                   <i class="fas fa-mobile-alt bg-green"></i> *@
@*                   <div class="timeline-item"> *@
@*                     <span class="time"><i class="fas fa-clock"></i> Q3/2023</span> *@
@*                     <h3 class="timeline-header">Phiên bản 2.0</h3> *@
@*                     <div class="timeline-body"> *@
@*                       Thêm ứng dụng di động và tích hợp API *@
@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*                 <div> *@
@*                   <i class="fas fa-robot bg-purple"></i> *@
