@*                       AI dự báo nhu cầu và tối ưu kho hàng *@
@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*               </div> *@
@*             </div> *@

@*           </div> *@
@*           <div class="card-footer text-center"> *@
