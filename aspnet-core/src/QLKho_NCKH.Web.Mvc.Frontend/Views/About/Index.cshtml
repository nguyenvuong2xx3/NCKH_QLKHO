@*                         <li>Giảm 95% sai sót thủ công</li> *@
@*                         <li>Tăng độ chính xác lên 99.9%</li> *@
@*                         <li>Hỗ trợ ra quyết định nhanh chóng</li> *@
@*                       </ul> *@
@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*               </div> *@
