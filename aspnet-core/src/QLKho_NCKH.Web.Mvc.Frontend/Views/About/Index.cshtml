@*                         <li>Theo dõi lịch sử xuất/nhập</li> *@
@*                         <li>Cảnh báo tồn kho tối thiểu</li> *@
@*                         <li>Báo cáo đa dạng, trực quan</li> *@
@*                       </ul> *@
@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*               </div> *@
@*               <div class="col-md-6"> *@
