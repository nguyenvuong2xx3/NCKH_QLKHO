@*                           <li><i class="fas fa-check text-success mr-2"></i>Docker Container</li> *@
@*                         </ul> *@
@*                       </div> *@
@*                       <div class="col-6"> *@
@*                         <ul class="list-unstyled"> *@
@*                           <li><i class="fas fa-check text-success mr-2"></i>Bootstrap 5</li> *@
@*                           <li><i class="fas fa-check text-success mr-2"></i>AdminLTE 3</li> *@
@*                           <li><i class="fas fa-check text-success mr-2"></i>SQL Server</li> *@
@*                         </ul> *@
@*                       </div> *@
@*                     </div> *@
@*                   </div> *@
@*                 </div> *@
@*               </div> *@
@*             </div> *@

@*             <div class="row mt-4"> *@
