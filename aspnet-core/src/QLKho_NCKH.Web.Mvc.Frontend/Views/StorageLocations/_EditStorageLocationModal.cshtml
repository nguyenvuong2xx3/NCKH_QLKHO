@using Abp.Authorization.Users
@using QLKho_NCKH.Web.Models.Common.Modals
@using QLKho_NCKH.Web.Models.storageLocations

@model EditStorageLocationViewModel
@{
	Layout = null;
}
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditStorageLocation")))
<script src="~/view-resources/Views/StorageLocations/_EditModal.js" asp-append-version="true"></script>

<form name="StorageLocationEditForm" role="form" class="form-horizontal">
  <input type="hidden" name="Id" value="@Model.Id" />
  <div class="modal-body">
    <div class="tab-content mt-4">
      <div role="tabpanel" class="tab-pane container active" id="create-supplier-details">
        <div class="form-group row required">
          <label class="col-md-3 col-form-label">@L("Code")</label>
          <div class="col-md-9">
            <input type="text" class="form-control" name="Code" value="@Model.Code" required maxlength="256"
                   placeholder="Nhập mã vị trí lưu trữ...">
          </div>
        </div>
        <div class="form-group row required">
          <label class="col-md-3 col-form-label">@L("WarehouseName")</label>
          <div class="input-group">
            <input type="text" id="WarehouseDisplayEdit" value="@Model.WarehouseName" class="form-control" readonly required
                   placeholder="Chọn kho..." />
            <button type="button" id="EditWarehouseBtn" class="btn btn-success btn-sm" title="@L("WarehouseName")">
              <i class="fa fa-id-card"></i>
            </button>
          </div>
          <input type="hidden" id="WarehouseIdEdit" name="WarehouseId" value="@Model.WarehouseId" />
        </div>
        <div class="form-group row required">
          <label class="col-md-3 col-form-label">@L("Capacity")</label>
          <div class="col-md-9">
            <input type="number" class="form-control" value="@Model.Capacity" name="Capacity" required maxlength="20"
                   placeholder="Nhập sức chứa (đơn vị)...">
          </div>
        </div>
        <div class="form-group row">
          <label class="col-md-3 col-form-label">@L("CurrentVolume")</label>
          <div class="col-md-9">
            <input type="number" class="form-control" value="@Model.CurrentVolume" name="CurrentVolume" maxlength="256"
                   placeholder="Nhập thể tích hiện tại (đơn vị)...">
          </div>
        </div>
        <div class="form-group row">
          <label class="col-md-3 col-form-label">@L("IsAvailable")</label>
          <div class="col-md-9">
            <input type="checkbox" name="IsAvailable" value="true" @(Model.IsAvailable ? "checked" : "") />
          </div>
        </div>
      </div>
    </div>
  </div>
  @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

