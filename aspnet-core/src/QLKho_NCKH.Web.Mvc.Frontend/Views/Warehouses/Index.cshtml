@using QLKho_NCKH.Web.Startup
@using QLKho_NCKH.Web.Models.Warehouses
@model WarehousesListViewModel
@{
  ViewBag.Title = L("Warehouses");
  ViewBag.CurrentPageName = PageNames.Warehouses;
}
@section scripts
{
  <environment names="Development">
    <script src="~/view-resources/Views/Warehouses/Index.js" asp-append-version="true"></script>
  </environment>

  <environment names="Staging,Production">
    <script src="~/view-resources/Views/Warehouses/Index.min.js" asp-append-version="true"></script>
  </environment>
}
<section class="content-header">
  <div class="container-fluid">
    <div class="row">
      <div class="col-sm-6">
        <h1>@L("Warehouses")</h1>
      </div>
      <div class="col-sm-6">
        <a href="javascript:;" data-toggle="modal" data-target="#WarehouseCreateModal" class="btn bg-blue float-sm-right">
          <i class="fa fa-plus-square"></i>
          @L("Create")
        </a>
      </div>
    </div>
  </div>
</section>
<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <div class="row">
              <div class="col-md-6">
                <!--Use for bulk actions-->
              </div>
              <div class="col-md-6">
                @await Html.PartialAsync("~/Views/Warehouses/Index.AdvancedSearch.cshtml")
              </div>
            </div>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table id="WarehousesTable" class="table table-striped table-bordered">
                <thead>
                  <tr>
                    <th>@L("Code")</th>
                    <th>@L("Name")</th>
                    <th>@L("Location")</th>
                    <th>@L("TotalArea")</th>
                    <th>@L("IsActive")</th>
                    <th>@L("Action")</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

@await Html.PartialAsync("~/Views/Warehouses/_CreateModal.cshtml", Model)

<div class="modal fade" id="WarehouseEditModal" tabindex="-1" role="dialog" aria-labelledby="UserEditModalLabel" data-backdrop="static">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
    </div>
  </div>
</div>
